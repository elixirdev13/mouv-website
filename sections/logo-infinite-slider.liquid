      "min": 5,
      "max": 60,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 20,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Text size",
      "min": 20,
      "max": 90,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo image width",
      "min": 60,
      "max": 400,
