<div
  class="floating-cta color-{{ section.settings.color_scheme }}"
  style="
    --floating-cta-height: {{ section.settings.section_height }}px;
    --floating-cta-mobile-height: {{ section.settings.mobile_section_height }}px;
    --floating-cta-heading-size: {{ section.settings.heading_size }}px;
    --floating-cta-image-size: {{ section.settings.image_size }}px;
    --floating-cta-mobile-image-size: {{ section.settings.mobile_image_size }}px;
  "
>
  <div class="floating-cta__inner section {{ section.settings.section_width }}">
    {% for block in section.blocks %}
      <div
        class="floating-cta__image floating-cta__image--{{ forloop.index }}"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 700
            | image_tag:
              loading: 'lazy',
              class: 'floating-cta__img',
              alt: block.settings.image.alt
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'floating-cta__img placeholder-svg' }}
        {% endif %}
      </div>
    {% endfor %}

    <div class="floating-cta__content">
      <h2>{{ section.settings.heading }}</h2>

      <div class="floating-cta__text">
        {{ section.settings.text }}
      </div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="floating-cta__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .floating-cta {
    overflow: hidden;
  }

  .floating-cta__inner {
    position: relative;
    min-height: var(--floating-cta-height);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
  }

  .floating-cta__content {
    position: relative;
    z-index: 2;
    max-width: 480px;
    text-align: center;
  }

  .floating-cta__content h2 {
    margin: 0 0 18px;
    font-family: 'Garalama', sans-serif !important;
    font-size: var(--floating-cta-heading-size);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .floating-cta__text {
    font-size: 14px;
    line-height: 1.6;
    letter-spacing: 1px;
  }

  .floating-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 135px;
    min-height: 42px;
    margin-block-start: 28px;
    padding: 0 24px;
    background: rgb(var(--color-foreground-rgb));
    color: rgb(var(--color-background-rgb));
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 1px;
  }

  .floating-cta__image {
    position: absolute;
    width: var(--floating-cta-image-size);
    height: var(--floating-cta-image-size);
    overflow: hidden;
    z-index: 1;
  }

  .floating-cta__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .floating-cta__image--1 {
    top: 18%;
    left: 3%;
  }

  .floating-cta__image--2 {
    top: 31%;
    left: 12%;
    width: calc(var(--floating-cta-image-size) * 0.72);
    height: calc(var(--floating-cta-image-size) * 0.72);
  }

  .floating-cta__image--3 {
    top: 0;
    left: 39%;
  }

  .floating-cta__image--4 {
    top: 22%;
    right: -2%;
  }

  .floating-cta__image--5 {
    bottom: 7%;
    right: 6%;
  }

  .floating-cta__image--6 {
    bottom: 4%;
    right: 17%;
    width: calc(var(--floating-cta-image-size) * 0.72);
    height: calc(var(--floating-cta-image-size) * 0.72);
  }

  .floating-cta__image--7 {
    bottom: 7%;
    left: 0;
  }

  .floating-cta__image--8 {
    bottom: 5%;
    left: 10%;
    width: calc(var(--floating-cta-image-size) * 1.25);
  }

  @media screen and (max-width: 749px) {
    .floating-cta__inner {
      min-height: var(--floating-cta-mobile-height);
    }

    .floating-cta__content {
      max-width: 310px;
    }

    .floating-cta__image {
      width: var(--floating-cta-mobile-image-size);
      height: var(--floating-cta-mobile-image-size);
    }

    .floating-cta__image--2,
    .floating-cta__image--6 {
      width: calc(var(--floating-cta-mobile-image-size) * 0.7);
      height: calc(var(--floating-cta-mobile-image-size) * 0.7);
    }

    .floating-cta__image--8 {
      width: calc(var(--floating-cta-mobile-image-size) * 1.15);
    }

    .floating-cta__image--3 {
      top: 2%;
      left: 36%;
    }

    .floating-cta__image--4 {
      right: -12%;
    }

    .floating-cta__image--7 {
      left: -8%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Floating image CTA",
  "tag": "section",
  "class": "floating-cta-wrapper section-wrapper",
  "blocks": [
    {
      "type": "image",
      "name": "Floating image",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lorem Ipsum"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Lorem ipsum dolor sit amet consectetur. Accumsan aliquam mi ac sapien sed eros.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Lorem Ipsum"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop section height",
      "min": 300,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 520
    },
    {
      "type": "range",
      "id": "mobile_section_height",
      "label": "Mobile section height",
      "min": 400,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Desktop image size",
      "min": 60,
      "max": 220,
      "step": 10,
      "unit": "px",
      "default": 130
    },
    {
      "type": "range",
      "id": "mobile_image_size",
      "label": "Mobile image size",
      "min": 50,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 90
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 70,
      "step": 1,
      "unit": "px",
      "default": 26
    }
  ],
  "presets": [
    {
      "name": "Floating image CTA",
      "category": "Custom",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}