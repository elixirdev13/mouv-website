<div
  class="editorial-collage color-{{ section.settings.color_scheme }}"
  style="
    --collage-padding-top: {{ section.settings.padding_top }}px;
    --collage-padding-bottom: {{ section.settings.padding_bottom }}px;
    --collage-heading-size: {{ section.settings.heading_size }}px;
    --collage-heading-spacing: {{ section.settings.heading_letter_spacing }}px;
    --collage-gap: {{ section.settings.gap }}px;
    --collage-row-height: {{ section.settings.row_height }}px;
    --collage-mobile-height: {{ section.settings.mobile_height }}px;
  "
>
  <div class="editorial-collage__inner section {{ section.settings.section_width }}">
    <div class="editorial-collage__header">
      <h2>{{ section.settings.heading_left }}</h2>
      <h2>{{ section.settings.heading_right }}</h2>
    </div>

    <div class="editorial-collage__grid">
      {% for block in section.blocks %}
        <div
          class="editorial-collage__item editorial-collage__item--{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'editorial-collage__image',
                alt: block.settings.image.alt
            }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'editorial-collage__placeholder' }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .editorial-collage {
    padding-block-start: var(--collage-padding-top);
    padding-block-end: var(--collage-padding-bottom);
  }

  .editorial-collage__inner {
    margin-inline: auto;
  }

  .editorial-collage__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    margin-block-end: 18px;
  }

  .editorial-collage__header h2 {
    margin: 0;
    font-family: 'Garalama', sans-serif !important;
    font-size: var(--collage-heading-size);
    font-weight: 400;
    line-height: 1;
    letter-spacing: var(--collage-heading-spacing);
    text-transform: uppercase;
  }

  .editorial-collage__grid {
    display: grid;
    grid-template-columns: 1.25fr 0.9fr 1.55fr 0.9fr;
    grid-template-rows: var(--collage-row-height) var(--collage-row-height);
    gap: var(--collage-gap);
  }

  .editorial-collage__item {
    overflow: hidden;
    min-height: 100%;
  }

  .editorial-collage__item--1 {
    grid-column: 1 / 2;
    grid-row: 1 / 3;
  }

  .editorial-collage__item--2 {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
  }

  .editorial-collage__item--3 {
    grid-column: 3 / 5;
    grid-row: 1 / 2;
  }

  .editorial-collage__item--4 {
    grid-column: 2 / 4;
    grid-row: 2 / 3;
  }

  .editorial-collage__item--5 {
    grid-column: 4 / 5;
    grid-row: 2 / 3;
  }

  .editorial-collage__image,
  .editorial-collage__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .editorial-collage__header h2 {
      font-size: 14px;
    }

    .editorial-collage__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }

    .editorial-collage__item {
      min-height: var(--collage-mobile-height);
    }

    .editorial-collage__item--1,
    .editorial-collage__item--2,
    .editorial-collage__item--3,
    .editorial-collage__item--4,
    .editorial-collage__item--5 {
      grid-column: auto;
      grid-row: auto;
    }

    .editorial-collage__item--1,
    .editorial-collage__item--3,
    .editorial-collage__item--4 {
      grid-column: span 2;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial image collage",
  "tag": "section",
  "class": "editorial-collage-wrapper section-wrapper",
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading_left",
      "label": "Left heading",
      "default": "Lorem Ipsum"
    },
    {
      "type": "text",
      "id": "heading_right",
      "label": "Right heading",
      "default": "Lorem Ipsum"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "row_height",
      "label": "Desktop image row height",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile image height",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 180
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": 0,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Image gap",
      "min": 4,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Editorial image collage",
      "category": "Custom",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}