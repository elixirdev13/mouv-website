<div
  class="story-collage color-{{ section.settings.color_scheme }}"
  style="
    --story-padding-top: {{ section.settings.padding_top }}px;
    --story-padding-bottom: {{ section.settings.padding_bottom }}px;
    --story-gap: {{ section.settings.gap }}px;
    --story-image-height: {{ section.settings.image_height }}px;
    --story-mobile-image-height: {{ section.settings.mobile_image_height }}px;
    --story-heading-size: {{ section.settings.heading_size }}px;
  "
>
  <div class="story-collage__inner section {{ section.settings.section_width }}">
    <div class="story-collage__grid">
      <div class="story-collage__heading">
        <h2>{{ section.settings.heading }}</h2>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'image' %}
          <div class="story-collage__image-item story-collage__image-item--{{ forloop.index }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  class: 'story-collage__image',
                  alt: block.settings.image.alt
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'story-collage__placeholder' }}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      <div class="story-collage__content">
        <div class="story-collage__text">
          {{ section.settings.text }}
        </div>

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="story-collage__button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .story-collage {
    padding-block-start: var(--story-padding-top);
    padding-block-end: var(--story-padding-bottom);
  }

  .story-collage__grid {
    display: grid;
    grid-template-columns: 0.95fr 0.95fr 0.95fr;
    grid-template-rows: var(--story-image-height) var(--story-image-height);
    gap: var(--story-gap);
  }

  .story-collage__heading {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
  }

  .story-collage__heading h2 {
    margin: 0;
    font-family: 'Garalama', sans-serif !important;
    font-size: var(--story-heading-size);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .story-collage__image-item {
    overflow: hidden;
  }

  .story-collage__image-item--1 {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
  }

  .story-collage__image-item--2 {
    grid-column: 3 / 4;
    grid-row: 1 / 2;
  }

  .story-collage__image-item--3 {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
  }

  .story-collage__image-item--4 {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
  }

  .story-collage__content {
    grid-column: 3 / 4;
    grid-row: 2 / 3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 22px 24px 0;
  }

  .story-collage__text {
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: 1px;
  }

  .story-collage__button {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    width: 100%;
    background: rgb(var(--color-foreground-rgb));
    color: rgb(var(--color-background-rgb));
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 1px;
  }

  .story-collage__image,
  .story-collage__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .story-collage__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .story-collage__heading,
    .story-collage__image-item--1,
    .story-collage__image-item--2,
    .story-collage__image-item--3,
    .story-collage__image-item--4,
    .story-collage__content {
      grid-column: auto;
      grid-row: auto;
    }

    .story-collage__image-item {
      height: var(--story-mobile-image-height);
    }

    .story-collage__content {
      padding: 0;
      gap: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Story image collage",
  "tag": "section",
  "class": "story-collage-wrapper section-wrapper",
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get to know our story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Lorem ipsum dolor sit amet consectetur. Accumsan aliquam mi ac sapien sed eros. Urna lacus lobortis facilisis nec sed sagittis.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Lorem Ipsum"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Desktop image height",
      "min": 160,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 330
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "label": "Mobile image height",
      "min": 160,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Story image collage",
      "category": "Custom",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}